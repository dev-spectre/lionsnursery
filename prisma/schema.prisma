generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id        String          @id @default(cuid())
  name      String          @unique
  slug      String          @unique
  plants    PlantCategory[]
  createdAt DateTime        @default(now())
}

model Plant {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  description String?
  price       Float
  imageUrl    String?
  inStock     Boolean         @default(true)
  deletedAt   DateTime?
  categories  PlantCategory[]
  orderItems  OrderItem[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model PlantCategory {
  plant      Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)
  plantId    String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String

  @@id([plantId, categoryId])
}

model HeroSlide {
  id        String   @id @default(cuid())
  imageUrl  String?
  title     String?
  subtitle  String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Coupon {
  id        String    @id @default(cuid())
  code      String    @unique
  discount  Float
  maxUses   Int?
  usedCount Int       @default(0)
  active    Boolean   @default(true)
  expiresAt DateTime?
  orders    Order[]
  createdAt DateTime  @default(now())
}

model Order {
  id           String      @id @default(cuid())
  customerName String
  phone        String
  address      String?
  message      String?
  couponCode   String?
  coupon       Coupon?     @relation(fields: [couponId], references: [id])
  couponId     String?
  subtotal     Float
  discount     Float       @default(0)
  total        Float
  status       OrderStatus @default(PENDING)
  items        OrderItem[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

enum OrderStatus {
  PENDING
  CONTACTED
  CONFIRMED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id        String @id @default(cuid())
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  plant     Plant  @relation(fields: [plantId], references: [id])
  plantId   String
  plantName String
  price     Float
  quantity  Int
}

model SiteSettings {
  id              String  @id @default("singleton")
  siteName        String  @default("Lions Landscape Nursery")
  tagline         String?
  aboutTitle      String?
  aboutBody       String? @db.Text
  phone           String?
  whatsapp        String?
  email           String?
  address         String?
  mapEmbedUrl     String?
  hours           String?
  footerText      String?
  metaTitle       String?
  metaDescription String?
  ogImageUrl      String?
}

// NextAuth Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

