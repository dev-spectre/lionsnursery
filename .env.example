# Database
DATABASE_URL=postgresql://user:password@host:5432/lions_nursery

# NixOS: use `nix-shell` (see shell.nix). Run `prisma` / `npm run db:*` inside that shell —
# do not use nixpkgs `prisma` (v7) or bare `npx` if your PATH has no Node.

# NextAuth v5
AUTH_SECRET=
AUTH_URL=https://lionslandscapenursery.com
# Dev: omit AUTH_EMAIL_SERVER to auto-create an Ethereal inbox (credentials print in the terminal).
# Prod: real SMTP, e.g. Gmail or your provider.
# AUTH_EMAIL_SERVER=smtp://user:pass@smtp.gmail.com:587
# AUTH_EMAIL_FROM=noreply@lionslandscapenursery.com
ADMIN_EMAIL=admin@lionslandscapenursery.com

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# SEO
GOOGLE_SITE_VERIFICATION=

# Vercel / production
# Set install/build command to: npm run build:vercel
# After first deploy, run: npm run db:seed (with production DATABASE_URL)
